# @huggingface/transformers depends on onnxruntime-node, whose postinstall
# downloads a native (CUDA) binary we never use — this extension runs purely on
# onnxruntime-web (WASM/WebGPU) in the browser. Skip dependency install scripts
# so that download can't break `pnpm install`. (Vite/esbuild get their binaries
# from optional dependencies, not install scripts, so they're unaffected.)
ignore-scripts=true
